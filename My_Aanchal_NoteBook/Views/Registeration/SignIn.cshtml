@* sign up modal popup *@

<div class="modal fade" id="signupModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="exampleModalLabel">New message</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="SignUp" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group">
                        <label asp-for="Code" class="control-label"></label>
                        <input asp-for="Code" class="form-control" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Name" class="control-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="HusbandName" class="control-label"></label>
                        <input asp-for="HusbandName" class="form-control" />
                        <span asp-validation-for="HusbandName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="EmailId" class="control-label"></label>
                        <input asp-for="EmailId" class="form-control" />
                        <span asp-validation-for="EmailId" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="PhoneNumber" class="control-label"></label>
                        <input name="PhoneNumber" id="modalPhoneNumber" readonly class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    @* <div class="form-group">
                        <label asp-for="PhoneNumber" class="control-label"></label>
                        <input readonly value="@ViewBag.MobileNumer" name="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div> *@
                    <div class="form-group">
                        <label asp-for="Address" class="control-label"></label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DairyName" class="control-label"></label>
                        <input asp-for="DairyName" class="form-control" />
                        <span asp-validation-for="DairyName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="DairyLocation" class="control-label"></label>
                        <input asp-for="DairyLocation" class="form-control" />
                        <span asp-validation-for="DairyLocation" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="SachiveName" class="control-label"></label>
                        <input asp-for="SachiveName" class="form-control" />
                        <span asp-validation-for="SachiveName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Password" class="control-label"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    @*  <div class="form-group">
                    <label asp-for="Otp" class="control-label"></label>
                    <input asp-for="Otp" class="form-control" />
                    <span asp-validation-for="Otp" class="text-danger"></span>
                    </div> *@
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <div class="form-group">
                            <input type="submit" value="Save" class="btn btn-primary" />
                        </div>
                    </div>
                    
                </form>
            </div>
            
        </div>
    </div>
</div>

